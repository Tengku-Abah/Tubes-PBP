--
-- Name: order_items Admins can view all order items; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admins can view all order items" ON public.order_items USING ((EXISTS ( SELECT 1
   FROM public.users
  WHERE ((users.id = auth.uid()) AND (users.role = 'admin'::text)))));


--
-- Name: categories Categories are viewable by everyone; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Categories are viewable by everyone" ON public.categories FOR SELECT USING (true);


--
-- Name: categories Categories full access for authenticated users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Categories full access for authenticated users" ON public.categories USING (true) WITH CHECK (true);


--
-- Name: products Enable all operations for products; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable all operations for products" ON public.products USING (true);


--
-- Name: cart_items Enable delete for cart owner; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable delete for cart owner" ON public.cart_items FOR DELETE USING (true);


--
-- Name: orders Enable insert for authenticated users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable insert for authenticated users" ON public.orders FOR INSERT WITH CHECK (true);


--
-- Name: reviews Enable insert for authenticated users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable insert for authenticated users" ON public.reviews FOR INSERT WITH CHECK (true);


--
-- Name: cart_items Enable insert for cart owner; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable insert for cart owner" ON public.cart_items FOR INSERT WITH CHECK (true);


--
-- Name: users Enable insert for public; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable insert for public" ON public.users FOR INSERT WITH CHECK (true);


--
-- Name: cart_items Enable select for cart owner; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable select for cart owner" ON public.cart_items FOR SELECT USING (true);


--
-- Name: orders Enable select for order owner; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable select for order owner" ON public.orders FOR SELECT USING (true);


--
-- Name: reviews Enable select for public; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable select for public" ON public.reviews FOR SELECT USING (true);


--
-- Name: users Enable select for public; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable select for public" ON public.users FOR SELECT USING (true);


--
-- Name: cart_items Enable update for cart owner; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable update for cart owner" ON public.cart_items FOR UPDATE USING (true);


--
-- Name: reviews Enable update for review owner; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable update for review owner" ON public.reviews FOR UPDATE USING (true);


--
-- Name: users Enable update for users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable update for users" ON public.users FOR UPDATE USING (true);


--
-- Name: order_items Users can view their own order items; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view their own order items" ON public.order_items FOR SELECT USING ((EXISTS ( SELECT 1
   FROM public.orders
  WHERE ((orders.id = order_items.order_id) AND (orders.user_id = auth.uid())))));


